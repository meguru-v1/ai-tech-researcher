# ───────────────────────────────────────────────────────────────
# AI Tech Researcher — 必要な環境変数の雛形（値は入れない）
# 使い方: このファイルを `.env.local` にコピーして各値を埋める。
#         `.env*` はコミット禁止（このexampleだけ追跡）。本番値は Vercel / GitHub Actions の secrets に設定。
# ───────────────────────────────────────────────────────────────

# ── データベース（Turso / libSQL）─────────────────────────────
# ⚠️ dev と本番でDBを分けること（ローカル開発が本番データを書き換えないよう、
#    ローカルは別DB or Tursoのブランチを指す）。本番直結はVibeCoding第四条「dev/本番分離」に反する。
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Gemini（@ai-sdk/google / @google/genai）──────────────────
GOOGLE_GENERATIVE_AI_API_KEY=

# ── 認証（Auth.js v5 / Google OAuth）─────────────────────────
# AUTH_SECRET は `npx auth secret` で生成。JWTセッション署名に必須。
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── オーナー判定（カンマ区切りでGoogleアカウントのメール許可リスト）──
OWNER_EMAIL=

# ── メール送信（Gmail SMTP / nodemailer）─────────────────────
# GMAIL_USER は送信専用アカウント、GMAIL_APP_PASSWORD はアプリパスワード。
# REPORT_TO はオーナー宛レポート(日次/週次/月次/失敗通知)の受信先（未設定ならGMAIL_USERへ自己送信）。
GMAIL_USER=
GMAIL_APP_PASSWORD=
REPORT_TO=

# ── 外部cron認証（JST06:00定刻駆動の /api/report 用 Bearer）───
CRON_SECRET=

# ── 公開メタ（NEXT_PUBLIC_* はクライアントにも露出する＝秘密を入れない）──
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_CONTACT_EMAIL=
# フィードバック用Googleフォーム（任意・送信先のformAction/entryフィールドID）
NEXT_PUBLIC_FEEDBACK_FORM_ACTION=
NEXT_PUBLIC_FEEDBACK_ENTRY=
NEXT_PUBLIC_FEEDBACK_ENTRY_EMAIL=

# ── 運用フラグ（任意・主にスクリプト/パイプライン実行時）─────────
# PIPELINE_MODE: daily_pipeline.ts の実行モード（deep/chunks/reembed/batch_submit/batch_fetch 等）
# SKIP_DAILY_REPORT_EMAIL=1 で日次レポートのメール送信を抑止
# BATCH_MAX / BATCH_CHUNK: Batch遡及再抽出の件数調整
# PIPELINE_MODE=
# SKIP_DAILY_REPORT_EMAIL=
